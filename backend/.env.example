NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://neuralpost:secret@localhost:5432/neuralpost

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Hugging Face (free - https://huggingface.co/settings/tokens)
HF_API_KEY=hf_your_api_key_here

# OpenAI (optional - for writing assistant & excerpt generation)
OPENAI_API_KEY=sk-your-openai-key-here

# Cloudinary (optional - for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
