# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# === JWT Secrets ===
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-replace-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-chars-here

# === AI API Keys ===
# Hugging Face (free): https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_key_here

# Google Gemini (optional): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# === Cloudinary (optional, for image uploads) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === Railway (for CI/CD deployment) ===
# RAILWAY_TOKEN=your-railway-token
